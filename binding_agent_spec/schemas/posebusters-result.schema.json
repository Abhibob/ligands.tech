{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "binding.dev/schemas/PoseBustersCheckResult.schema.json",
  "title": "PoseBustersCheckResult",
  "type": "object",
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "tool",
    "status",
    "summary"
  ],
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "binding.dev/v1"
    },
    "kind": {
      "type": "string",
      "const": "PoseBustersCheckResult"
    },
    "metadata": {
      "type": "object",
      "required": [
        "requestId",
        "createdAt"
      ],
      "properties": {
        "requestId": {
          "type": "string",
          "minLength": 1
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "labels": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "tool": {
      "type": "string"
    },
    "toolVersion": {
      "type": "string"
    },
    "wrapperVersion": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "succeeded",
        "failed",
        "partial"
      ]
    },
    "inputsResolved": {
      "type": "object"
    },
    "parametersResolved": {
      "type": "object"
    },
    "summary": {
      "type": "object",
      "properties": {
        "poses": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "inputPath": {
                "type": "string"
              },
              "passesAllChecks": {
                "type": "boolean"
              },
              "passFraction": {
                "type": "number"
              },
              "fatalFailures": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "majorFailures": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "minorFailures": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "failedChecks": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": true
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": true
    },
    "runtimeSeconds": {
      "type": "number"
    }
  },
  "additionalProperties": true
}
