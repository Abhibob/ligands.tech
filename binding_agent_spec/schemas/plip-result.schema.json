{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "binding.dev/schemas/PlipProfileResult.schema.json",
  "title": "PlipProfileResult",
  "type": "object",
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "tool",
    "status",
    "summary"
  ],
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "binding.dev/v1"
    },
    "kind": {
      "type": "string",
      "const": "PlipProfileResult"
    },
    "metadata": {
      "type": "object",
      "required": [
        "requestId",
        "createdAt"
      ],
      "properties": {
        "requestId": {
          "type": "string",
          "minLength": 1
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "labels": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "tool": {
      "type": "string"
    },
    "toolVersion": {
      "type": "string"
    },
    "wrapperVersion": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "succeeded",
        "failed",
        "partial"
      ]
    },
    "inputsResolved": {
      "type": "object"
    },
    "parametersResolved": {
      "type": "object"
    },
    "summary": {
      "type": "object",
      "properties": {
        "bindingSites": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "selectedBindingSite": {
          "type": "string"
        },
        "interactionCounts": {
          "type": "object",
          "additionalProperties": {
            "type": "integer"
          }
        },
        "interactingResidues": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "interactionsByType": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          }
        }
      },
      "additionalProperties": true
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": true
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": true
    },
    "runtimeSeconds": {
      "type": "number"
    }
  },
  "additionalProperties": true
}
